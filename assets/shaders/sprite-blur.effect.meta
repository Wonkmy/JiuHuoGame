        "frag": "\nprecision highp float;\nuniform sampler2D texture;\nuniform vec4 blurParams;\nvarying vec2 v_uv0;\nvarying vec4 v_color;\nvec4 sampleBlur(vec2 offset) {\n  vec4 c = vec4(1.0);\n  vec4 texture_tmp = texture2D(texture, v_uv0 + offset);\n  #if CC_USE_ALPHA_ATLAS_texture\n      texture_tmp.a *= texture2D(texture, v_uv0 + offset + vec2(0, 0.5)).r;\n  #endif\n  #if INPUT_IS_GAMMA\n    c.rgb *= (texture_tmp.rgb * texture_tmp.rgb);\n    c.a *= texture_tmp.a;\n  #else\n    c *= texture_tmp;\n  #endif\n  return c;\n}\nvoid main () {\n  float blurRadius = blurParams.x;\n  vec2 texelSize = blurParams.yz;\n  vec2 p = texelSize * blurRadius;\n  vec4 color = vec4(0.0);\n  color += sampleBlur(vec2(0.0, 0.0)) * 0.20;\n  color += sampleBlur(vec2( p.x, 0.0)) * 0.12;\n  color += sampleBlur(vec2(-p.x, 0.0)) * 0.12;\n  color += sampleBlur(vec2(0.0,  p.y)) * 0.12;\n  color += sampleBlur(vec2(0.0, -p.y)) * 0.12;\n  color += sampleBlur(vec2( p.x,  p.y)) * 0.08;\n  color += sampleBlur(vec2(-p.x,  p.y)) * 0.08;\n  color += sampleBlur(vec2( p.x, -p.y)) * 0.08;\n  color += sampleBlur(vec2(-p.x, -p.y)) * 0.08;\n  color *= v_color;\n  gl_FragColor = color;\n}"
